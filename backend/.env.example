MONGO_URI=mongodb+srv://KaviyaShanmugam:Kaviya12345@cluster0.ujzcjba.mongodb.net/bakery_bot?retryWrites=true&w=majority

# ===================================
# WHATSAPP CLOUD API (Meta)
# ===================================
WHATSAPP_TOKEN=your_meta_permanent_or_temp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id
WHATSAPP_VERIFY_TOKEN=bakery_webhook_verify_123
WHATSAPP_API_VERSION=v20.0

# ===================================
# BAKERY INFO
# ===================================
BAKERY_NAME=Sweet  Bakery
BAKERY_PHONE=+919999999999
BAKERY_ADDRESS=123 Main Street, Rameswaram, Tamil Nadu
GST_PERCENTAGE=5

# ===================================
# META WHATSAPP FLOW (encrypted data endpoint)
# ===================================
# Generate with: openssl genrsa -out private.pem 2048  (upload the matching
# public key in Meta App Dashboard -> WhatsApp -> Flows -> your flow -> Endpoint)
# Paste the private key here with literal \n for line breaks, e.g.:
# FLOW_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----"
FLOW_PRIVATE_KEY=
FLOW_PRIVATE_KEY_PASSPHRASE=
FLOW_ID=

# ===================================
# JWT (Admin Dashboard Auth)
# ===================================
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ===================================
# ADMIN SEED USER (used by seed script)
# ===================================
ADMIN_EMAIL=admin@bakery.com
ADMIN_PASSWORD=Admin@123

# ===================================
# CORS
# ===================================
FRONTEND_URL=http://localhost:5173
